# PostgreSQL connection string.
# Local dev (Docker compose service in this repo): postgresql://meal:meal@localhost:5432/mealplanning
# Production (Coolify): use the connection string Coolify gives your Postgres resource.
DATABASE_URL="postgresql://meal:meal@localhost:5432/mealplanning"

# Auth.js (NextAuth v5) secret. Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-long-random-string"

# Public base URL of the app. Local: http://localhost:3000  Prod: https://your-domain
AUTH_URL="http://localhost:3000"
