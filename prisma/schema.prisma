// Prisma schema for the meal planning PWA.
// Provider: PostgreSQL (Coolify-managed in production).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String?
  heightCm      Float?
  targetKcal    Int?
  targetProtein Int?
  targetFat     Int?
  targetCarbs   Int?
  targetSugar   Int?
  targetFiber   Int?
  units         Units    @default(METRIC)

  meals          Meal[]
  tags           Tag[]
  planEntries    PlanEntry[]
  bodyweights    BodyweightLog[]
  shoppingChecks ShoppingCheck[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Meal {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  prepSteps    String? // free text / step list (optional)
  servingLabel String? // describes the 1-serving baseline, e.g. "1 bowl"
  serves       Float   @default(1) // how many servings the whole recipe yields
  // Per-serving macros. Either typed in by hand or computed from scanned
  // ingredients (sum ÷ serves); `macrosManual` records which, so edits restore
  // the right mode.
  macrosManual Boolean @default(false)
  kcal         Float?
  protein      Float? // grams
  fat          Float?
  carbs        Float?
  sugar        Float?
  fiber        Float?

  ingredients Ingredient[]
  tags        MealTag[]
  planEntries PlanEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Ingredient {
  id       String  @id @default(cuid())
  mealId   String
  meal     Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  name     String // required
  qty      Float? // optional (hybrid); grams when scanned from a barcode
  unit     String? // optional: ml, g, tbsp, pcs...
  note     String?
  position Int     @default(0)
  // Set when the ingredient was added by scanning a product. Macros are stored
  // per 100 g/ml; the ingredient's contribution is macros × qty/100.
  barcode  String?
  kcal     Float?
  protein  Float?
  fat      Float?
  carbs    Float?
  sugar    Float?
  fiber    Float?

  @@index([mealId])
}

model Tag {
  id     String    @id @default(cuid())
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  color  String?
  meals  MealTag[]

  @@unique([userId, name])
  @@index([userId])
}

model MealTag {
  mealId String
  tagId  String
  meal   Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([mealId, tagId])
  @@index([tagId])
}

// A day+slot entry. References EITHER a prebuilt meal (scaled by `servings`) or a
// scanned product (scaled by `grams`). Exactly one of mealId/productId is set —
// enforced in the server actions, not at the DB level.
model PlanEntry {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime    @db.Date
  slot      Slot
  mealId    String?
  meal      Meal?       @relation(fields: [mealId], references: [id], onDelete: Restrict)
  productId String?
  product   Product?    @relation(fields: [productId], references: [id], onDelete: Restrict)
  servings  Float       @default(1) // used for meal entries
  grams     Float? // used for product entries
  status    EntryStatus @default(PLANNED)
  position  Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([userId, date])
  @@index([mealId])
  @@index([productId])
}

// App-wide cache of scanned products, keyed by barcode. Macros are stored per
// 100 g/ml (canonical). Populated from Open Food Facts on first log and
// overridable by users (source flips to "user" once hand-edited).
model Product {
  id String @id @default(cuid())
  // Null for hand-entered foods: butcher's meat, loose produce, anything whose
  // packaging is long gone. Postgres allows many NULLs under a unique index, so
  // barcoded products still can't collide.
  barcode      String? @unique
  name         String
  brand        String?
  servingLabel String? // free text e.g. "30 g"
  servingGrams Float? // parsed numeric serving for the "1 serving" shortcut
  kcal         Float? // all per 100 g/ml
  protein      Float?
  fat          Float?
  carbs        Float?
  sugar        Float?
  fiber        Float?
  source       String  @default("openfoodfacts") // "user" once hand-edited

  planEntries PlanEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BodyweightLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightKg   Float
  recordedAt DateTime @db.Date
  note       String?
  createdAt  DateTime @default(now())

  @@unique([userId, recordedAt])
  @@index([userId, recordedAt])
}

// Persisted check-off state for the dynamically-computed shopping list.
// Keyed by normalized "name|unit" so it survives plan changes.
model ShoppingCheck {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemKey   String
  checked   Boolean  @default(true)
  checkedAt DateTime @default(now())

  @@unique([userId, itemKey])
  @@index([userId])
}

enum Slot {
  BREAKFAST
  SNACK_1
  LUNCH
  SNACK_2
  DINNER
}

enum EntryStatus {
  PLANNED
  EATEN
  SKIPPED
}

enum Units {
  METRIC
  IMPERIAL
}
